{{ 'custom-footer.css' | asset_url | stylesheet_tag }}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<footer class="custom-footer section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  role="contentinfo"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="custom-footer__container page-width-content">
    <!-- Top section -->
    <div class="custom-footer__top">
      <!-- Brand column -->
      <div class="custom-footer__brand">
        <div class="custom-footer__brand-mark">
            {% if section.settings.brand_logo != blank %}
              {{
                section.settings.brand_logo
                | image_url: width: 360
                | image_tag:
                  loading: 'lazy',
                  class: 'custom-footer__brand-logo',
                  alt: section.settings.brand_title | default: shop.name
              }}
            {% endif %}
            {% if section.settings.brand_title != blank %}
              <p class="custom-footer__brand-title">
                {{ section.settings.brand_title }}
              </p>
            {% endif %}
          </div>


        {% if section.settings.brand_description != blank %}
          <p class="custom-footer__brand-description">{{ section.settings.brand_description }}</p>
        {% endif %}

        {% if section.settings.contact_text != blank or section.settings.phone != blank or section.settings.email != blank %}
          <div class="custom-footer__support">
            {% if section.settings.contact_text != blank %}
              <p class="custom-footer__support-text">{{ section.settings.contact_text }}</p>
            {% endif %}
            <div class="custom-footer__support-links">
              {% if section.settings.phone != blank %}
                <a
                  href="tel:{{ section.settings.phone | replace: ' ', '' | replace: '-', '' }}"
                  class="custom-footer__support-link"
                >
                  {{ section.settings.phone }}
                </a>
              {% endif %}
              {% if section.settings.email != blank %}
                <a href="mailto:{{ section.settings.email }}" class="custom-footer__support-link">
                  {{ section.settings.email }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}

        {% if section.settings.show_social %}
          <div class="custom-footer__social">
            <ul class="custom-footer__social-icons list-unstyled">
              {% if section.settings.social_facebook != blank %}
                <li>
                  <a href="{{ section.settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook" class="custom-footer__social-link">
                    {% if section.settings.social_facebook_icon != blank %}
                      <img src="{{ section.settings.social_facebook_icon | image_url: width: 40 }}" alt="Facebook" width="20" height="20" loading="lazy">
                    {% else %}
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    {% endif %}
                  </a>
                </li>
              {% endif %}
              {% if section.settings.social_instagram != blank %}
                <li>
                  <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram" class="custom-footer__social-link">
                    {% if section.settings.social_instagram_icon != blank %}
                      <img src="{{ section.settings.social_instagram_icon | image_url: width: 40 }}" alt="Instagram" width="20" height="20" loading="lazy">
                    {% else %}
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                    {% endif %}
                  </a>
                </li>
              {% endif %}
              {% if section.settings.social_twitter != blank %}
                <li>
                  <a href="{{ section.settings.social_twitter }}" target="_blank" rel="noopener" aria-label="Twitter / X" class="custom-footer__social-link">
                    {% if section.settings.social_twitter_icon != blank %}
                      <img src="{{ section.settings.social_twitter_icon | image_url: width: 40 }}" alt="Twitter / X" width="20" height="20" loading="lazy">
                    {% else %}
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    {% endif %}
                  </a>
                </li>
              {% endif %}
              {% if section.settings.social_youtube != blank %}
                <li>
                  <a href="{{ section.settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube" class="custom-footer__social-link">
                    {% if section.settings.social_youtube_icon != blank %}
                      <img src="{{ section.settings.social_youtube_icon | image_url: width: 40 }}" alt="YouTube" width="20" height="20" loading="lazy">
                    {% else %}
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    {% endif %}
                  </a>
                </li>
              {% endif %}
              {% if section.settings.social_linkedin != blank %}
                <li>
                  <a href="{{ section.settings.social_linkedin }}" target="_blank" rel="noopener" aria-label="LinkedIn" class="custom-footer__social-link">
                    {% if section.settings.social_linkedin_icon != blank %}
                      <img src="{{ section.settings.social_linkedin_icon | image_url: width: 40 }}" alt="LinkedIn" width="20" height="20" loading="lazy">
                    {% else %}
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    {% endif %}
                  </a>
                </li>
              {% endif %}
              {% if section.settings.social_tiktok != blank %}
                <li>
                  <a href="{{ section.settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok" class="custom-footer__social-link">
                    {% if section.settings.social_tiktok_icon != blank %}
                      <img src="{{ section.settings.social_tiktok_icon | image_url: width: 40 }}" alt="TikTok" width="20" height="20" loading="lazy">
                    {% else %}
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
                    {% endif %}
                  </a>
                </li>
              {% endif %}
              {% if section.settings.social_pinterest != blank %}
                <li>
                  <a href="{{ section.settings.social_pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest" class="custom-footer__social-link">
                    {% if section.settings.social_pinterest_icon != blank %}
                      <img src="{{ section.settings.social_pinterest_icon | image_url: width: 40 }}" alt="Pinterest" width="20" height="20" loading="lazy">
                    {% else %}
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12.017 24c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641 0 12.017 0z"/></svg>
                    {% endif %}
                  </a>
                </li>
              {% endif %}
            </ul>
          </div>
        {% endif %}
      </div>

      <!-- Menu Links -->
      <div class="custom-footer__menus">
        {% for block in section.blocks %}
          {% if block.type == 'menu' %}
            <div class="custom-footer__menu-column">
              {% if block.settings.heading != blank %}
                <h4 class="custom-footer__menu-heading">{{ block.settings.heading }}</h4>
              {% endif %}
              {% if block.settings.menu != blank %}
                <ul class="custom-footer__menu-list list-unstyled">
                  {% for link in linklists[block.settings.menu].links %}
                    <li>
                      <a href="{{ link.url }}" class="custom-footer__menu-link">
                        {{ link.title }}
                      </a>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <!-- Newsletter Section -->
      <div class="custom-footer__newsletter">
        {% if section.settings.newsletter_title != blank %}
          <h3 class="custom-footer__newsletter-title">{{ section.settings.newsletter_title }}</h3>
        {% endif %}
        {% if section.settings.newsletter_description != blank %}
          <p class="custom-footer__newsletter-description">{{ section.settings.newsletter_description }}</p>
        {% endif %}
        {% form 'customer', class: 'custom-footer__newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="custom-footer__newsletter-controls">
            <label class="visually-hidden" for="NewsletterForm--{{ section.id }}">{{ section.settings.email_placeholder }}</label>
            <div class="custom-footer__input-wrapper">
              <span class="custom-footer__input-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M4 7a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z" />
                  <path d="m4 7 8 6 8-6" />
                </svg>
              </span>
              <input
                id="NewsletterForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="custom-footer__newsletter-input"
                value="{{ form.email }}"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}
                  autofocus
                  aria-invalid="true"
                  aria-describedby="Newsletter-error--{{ section.id }}"
                {% elsif form.posted_successfully? %}
                  aria-describedby="Newsletter-success--{{ section.id }}"
                {% endif %}
                placeholder="{{ section.settings.email_placeholder }}"
              >
            </div>
            <button type="submit" class="custom-footer__newsletter-button" name="commit">
              {{ section.settings.button_text }}
            </button>
          </div>
          {%- if form.errors -%}
            <small class="custom-footer__newsletter-error" id="Newsletter-error--{{ section.id }}">
              {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
            </small>
          {%- endif -%}
          {%- if form.posted_successfully? -%}
            <small class="custom-footer__newsletter-success" id="Newsletter-success--{{ section.id }}">
              {{ 'newsletter.success' | t }}
            </small>
          {%- endif -%}
        {% endform %}
      </div>
    </div>

    <!-- Bottom section with payment and copyright -->
    <div class="custom-footer__bottom">


      <div class="custom-footer__copyright">
        <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_text }}</p>
        {% if section.settings.show_policy_links and shop.policies.size > 0 %}
          <div class="custom-footer__policies">
            <ul class="custom-footer__policy-list">
              {% for policy in shop.policies %}
                {% if policy != blank %}
                  <li>
                    <a href="{{ policy.url }}" class="custom-footer__policy-link">{{ policy.title }}</a>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Footer",
  "class": "custom-footer-section",
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "info": "Select a menu to display"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Brand Information"
    },
    {
      "type": "image_picker",
      "id": "brand_logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "brand_title",
      "label": "Brand Title",
      "info": "Leave blank to use shop name."
    },
    {
      "type": "richtext",
      "id": "brand_description",
      "label": "Brand Description"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Title",
      "default": "Sign up for our newsletter"
    },
    {
      "type": "textarea",
      "id": "newsletter_description",
      "label": "Description",
      "default": "Be the first to know about our new collections, exclusive offers and promotions."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "header",
      "content": "Contact Information"
    },
    {
      "type": "textarea",
      "id": "contact_text",
      "label": "Contact text",
      "default": "Our customer service team is here to help"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "+1 (555) 123-4567"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "support@petsetgo.com"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social media icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Social Media Links"
    },
    {
      "type": "image_picker",
      "id": "social_facebook_icon",
      "label": "Facebook icon"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook link"
    },
    {
      "type": "image_picker",
      "id": "social_instagram_icon",
      "label": "Instagram icon"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram link"
    },
    {
      "type": "image_picker",
      "id": "social_twitter_icon",
      "label": "Twitter / X icon"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter / X link"
    },
    {
      "type": "image_picker",
      "id": "social_youtube_icon",
      "label": "YouTube icon"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube link"
    },
    {
      "type": "image_picker",
      "id": "social_linkedin_icon",
      "label": "LinkedIn icon"
    },
    {
      "type": "url",
      "id": "social_linkedin",
      "label": "LinkedIn link"
    },
    {
      "type": "image_picker",
      "id": "social_tiktok_icon",
      "label": "TikTok icon"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok link"
    },
    {
      "type": "image_picker",
      "id": "social_pinterest_icon",
      "label": "Pinterest icon"
    },
    {
      "type": "url",
      "id": "social_pinterest",
      "label": "Pinterest link"
    },
    {
      "type": "header",
      "content": "Color Scheme"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Background color",
      "default": "#f8f9fa"
    },
    {
      "type": "color",
      "id": "custom_text_color",
      "label": "Text color",
      "default": "#374151"
    },
    {
      "type": "color",
      "id": "custom_link_color",
      "label": "Link color",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "custom_heading_color",
      "label": "Heading color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "custom_border_color",
      "label": "Border color",
      "default": "#e5e7eb"
    },
    {
      "type": "header",
      "content": "Payment & Copyright"
    },
    {
      "type": "checkbox",
      "id": "show_payment",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "text",
      "id": "payment_text",
      "label": "Payment text",
      "default": "We accept:"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_policy_links",
      "label": "Show policy links",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Custom Footer",
      "blocks": [
        {
          "type": "menu",
          "settings": {
            "heading": "Shop",
            "menu": "main-menu"
          }
        },
        {
          "type": "menu",
          "settings": {
            "heading": "Help",
            "menu": "footer"
          }
        }
      ]
    }
  ]
}
{% endschema %}