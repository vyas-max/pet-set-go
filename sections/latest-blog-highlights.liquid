{% liquid
  assign blog = section.settings.blog
  assign article_limit = section.settings.article_limit
  assign highlight_color = section.settings.highlight_color | default: '#F48F01'

  assign has_articles = false
  if blog != blank and blog.articles_count > 0
    assign has_articles = true
  endif

  assign show_desktop_nav = false
  if article_limit > 3
    assign show_desktop_nav = true
  endif
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<section
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    latest-blog-highlights
    spacing-style
  "
  style="
    --latest-blog-highlight-color: {{ highlight_color }};
    {%- render 'spacing-style', settings: section.settings -%}
  "
  data-latest-blog-section="{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="latest-blog-highlights__inner">
    {% if
      section.settings.eyebrow != blank
      or section.settings.heading_prefix != blank
      or section.settings.heading_highlight != blank
      or section.settings.heading_suffix != blank
      or section.settings.subheading != blank
    %}
      <header class="latest-blog-highlights__header">
        <div class="latest-blog-highlights__header-text">
          {% if section.settings.eyebrow != blank %}
            <p class="latest-blog-highlights__eyebrow">{{ section.settings.eyebrow }}</p>
          {% endif %}

          {% if section.settings.heading_prefix != blank
            or section.settings.heading_highlight != blank
            or section.settings.heading_suffix != blank
          %}
            <h2 class="latest-blog-highlights__title">
              {% if section.settings.heading_prefix != blank %}
                <span>{{ section.settings.heading_prefix }}</span>
              {% endif %}
              {% if section.settings.heading_highlight != blank %}
                <span class="latest-blog-highlights__title-highlight">
                  {{ section.settings.heading_highlight }}
                </span>
              {% endif %}
              {% if section.settings.heading_suffix != blank %}
                <span>{{ section.settings.heading_suffix }}</span>
              {% endif %}
            </h2>
          {% endif %}

          {% if section.settings.subheading != blank %}
            <p class="latest-blog-highlights__subtitle">
              {{ section.settings.subheading }}
            </p>
          {% endif %}
        </div>

        {% if show_desktop_nav %}
          <div class="latest-blog-highlights__nav" aria-label="Blog carousel navigation">
            <button
              class="latest-blog-highlights__nav-btn latest-blog-highlights__nav-btn--prev"
              type="button"
              data-blog-nav="prev"
              aria-label="{{ 'accessibility.previous_slide' | t | default: 'Previous posts' }}"
            >
              &lsaquo;
            </button>
            <button
              class="latest-blog-highlights__nav-btn latest-blog-highlights__nav-btn--next"
              type="button"
              data-blog-nav="next"
              aria-label="{{ 'accessibility.next_slide' | t | default: 'Next posts' }}"
            >
              &rsaquo;
            </button>
          </div>
        {% endif %}
      </header>
    {% endif %}

    {% liquid
      assign cards_classes = 'latest-blog-highlights__cards'
      if show_desktop_nav
        assign cards_classes = cards_classes | append: ' latest-blog-highlights__cards--scroll'
      endif
    %}

    <div class="{{ cards_classes }}" data-blog-scroller>
      {% if has_articles %}
        {% for article in blog.articles limit: article_limit %}
          {% assign excerpt = article.excerpt_or_content | strip_html | truncatewords: section.settings.excerpt_words, '…' %}
          <article class="latest-blog-card">
            <div class="latest-blog-card__media">
              {% if article.image %}
                {{
                  article.image
                  | image_url: width: 900
                  | image_tag:
                    loading: 'lazy',
                    alt: article.title,
                    class: 'latest-blog-card__image'
                }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'latest-blog-card__placeholder' }}
              {% endif %}
            </div>

            <div class="latest-blog-card__content">
              <h3 class="latest-blog-card__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h3>
              <p class="latest-blog-card__excerpt">{{ excerpt }}</p>
              <a class="latest-blog-card__link" href="{{ article.url }}">
                {{ section.settings.card_cta_label }}
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        {% endfor %}
      {% else %}
        {% for i in (1..article_limit) %}
          <article class="latest-blog-card latest-blog-card--placeholder">
            <div class="latest-blog-card__media">
              {{ 'image' | placeholder_svg_tag: 'latest-blog-card__placeholder' }}
            </div>
            <div class="latest-blog-card__content">
              <h3 class="latest-blog-card__title">
                {{ 'onboarding.latest_blog.title' | t | default: 'Which kind of raincoat is best for your pet?' }}
              </h3>
              <p class="latest-blog-card__excerpt">
                {{ 'onboarding.latest_blog.body' | t | default: 'Lorem ipsum is simply dummy text of the printing and typesetting industry.' }}
              </p>
              <span class="latest-blog-card__link">
                {{ section.settings.card_cta_label }}
                <span aria-hidden="true">→</span>
              </span>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.show_view_all %}
      <div class="latest-blog-highlights__footer">
        <a
          class="latest-blog-highlights__cta"
          href="{% if has_articles %}{{ blog.url }}{% else %}#{% endif %}"
        >
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% javascript %}
  const latestBlogSectionSelector = '[data-latest-blog-section]';

  function initLatestBlogHighlights(root = document) {
    const sections = root.querySelectorAll(latestBlogSectionSelector);

    sections.forEach((section) => {
      if (section.dataset.latestBlogInit === 'true') {
        return;
      }

      const scroller = section.querySelector('[data-blog-scroller]');
      const prevButton = section.querySelector('[data-blog-nav="prev"]');
      const nextButton = section.querySelector('[data-blog-nav="next"]');

      if (!scroller) {
        return;
      }

      section.dataset.latestBlogInit = 'true';

      const cards = scroller.querySelectorAll('.latest-blog-card');
      if (!cards.length) {
        return;
      }

      const firstCard = cards[0];

      function getScrollAmount() {
        const rect = firstCard.getBoundingClientRect();
        const styles = window.getComputedStyle(scroller);
        const gapValue = styles.columnGap || styles.gap || '0';
        const gap = parseFloat(gapValue) || 0;
        return rect.width + gap;
      }

      function scrollByDirection(direction) {
        const amount = getScrollAmount() * direction;
        const newLeft = scroller.scrollLeft + amount;

        if (typeof scroller.scrollTo === 'function') {
          scroller.scrollTo({ left: newLeft, behavior: 'smooth' });
        } else {
          scroller.scrollLeft = newLeft;
        }
      }

      if (prevButton && nextButton) {
        prevButton.addEventListener('click', () => scrollByDirection(-1));
        nextButton.addEventListener('click', () => scrollByDirection(1));
      }

      // Mobile touch drag slider functionality
      let isDown = false;
      let startX;
      let scrollLeftStart;
      let velX = 0;
      let momentumID = null;
      const friction = 0.92;

      function isMobile() {
        return window.innerWidth < 700;
      }

      scroller.addEventListener('mousedown', (e) => {
        if (!isMobile()) return;
        isDown = true;
        scroller.classList.add('is-dragging');
        startX = e.pageX - scroller.offsetLeft;
        scrollLeftStart = scroller.scrollLeft;
        cancelMomentum();
      });

      scroller.addEventListener('mouseleave', () => {
        if (!isMobile()) return;
        if (isDown) {
          isDown = false;
          scroller.classList.remove('is-dragging');
          beginMomentum();
        }
      });

      scroller.addEventListener('mouseup', () => {
        if (!isMobile()) return;
        isDown = false;
        scroller.classList.remove('is-dragging');
        beginMomentum();
      });

      scroller.addEventListener('mousemove', (e) => {
        if (!isMobile() || !isDown) return;
        e.preventDefault();
        const x = e.pageX - scroller.offsetLeft;
        const walk = (x - startX) * 1.5;
        const prevScrollLeft = scroller.scrollLeft;
        scroller.scrollLeft = scrollLeftStart - walk;
        velX = scroller.scrollLeft - prevScrollLeft;
      });

      // Touch events for mobile
      let touchStartX;
      let touchScrollLeft;

      scroller.addEventListener('touchstart', (e) => {
        if (!isMobile()) return;
        touchStartX = e.touches[0].pageX;
        touchScrollLeft = scroller.scrollLeft;
        scroller.classList.add('is-touching');
        cancelMomentum();
      }, { passive: true });

      scroller.addEventListener('touchmove', (e) => {
        if (!isMobile()) return;
        const x = e.touches[0].pageX;
        const walk = (touchStartX - x) * 1.2;
        const prevScrollLeft = scroller.scrollLeft;
        scroller.scrollLeft = touchScrollLeft + walk;
        velX = scroller.scrollLeft - prevScrollLeft;
      }, { passive: true });

      scroller.addEventListener('touchend', () => {
        if (!isMobile()) return;
        scroller.classList.remove('is-touching');
        beginMomentum();
      }, { passive: true });

      function beginMomentum() {
        cancelMomentum();
        momentumID = requestAnimationFrame(momentumLoop);
      }

      function cancelMomentum() {
        if (momentumID) {
          cancelAnimationFrame(momentumID);
          momentumID = null;
        }
      }

      function momentumLoop() {
        scroller.scrollLeft += velX;
        velX *= friction;
        
        if (Math.abs(velX) > 0.5) {
          momentumID = requestAnimationFrame(momentumLoop);
        }
      }
    });
  }

  document.addEventListener('DOMContentLoaded', () => initLatestBlogHighlights());
  document.addEventListener('shopify:section:load', (event) => {
    initLatestBlogHighlights(event.target);
  });
{% endjavascript %}

{% stylesheet %}
  .latest-blog-highlights {
    position: relative;
    overflow-x: hidden;
  }

  .latest-blog-highlights__inner {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .latest-blog-highlights__header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .latest-blog-highlights__header-text {
    text-align: left;
    max-width: 740px;
    margin-inline: auto;
  }

  .latest-blog-highlights__eyebrow {
    font-size: 0.95rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, currentColor 70%, transparent);
    margin-bottom: 0.5rem;
  }

  .latest-blog-highlights__title {
    font-size: 60px;
    font-weight: 400;
    margin: 0;
    line-height: 1.15;
    display: flex;
    flex-wrap: wrap;
    justify-content: left;
    gap: 0.35rem;
  }

  .latest-blog-highlights__title-highlight {
    color: var(--latest-blog-highlight-color);
  }

  .latest-blog-highlights__subtitle {
    font-size: 1.125rem;
    color: color-mix(in srgb, currentColor 75%, transparent);
    margin: 0.75rem auto 0;
  }

  .latest-blog-highlights__nav {
    display: none;
  }

  .latest-blog-highlights__nav-btn {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, currentColor 30%, transparent);
    background: rgb(var(--color-page-background));
    color: inherit;
    font-size: 1.35rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 1px 3px rgb(15 23 42 / 0.12),
      0 0 0 1px rgb(255 255 255 / 0.6) inset;
    transition: background 150ms ease, color 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
  }

  .latest-blog-highlights__nav-btn:hover {
    background: var(--latest-blog-highlight-color);
    color: #F48F01;
    border-color: transparent;
    box-shadow: 0 10px 20px rgb(0 0 0 / 0.15);
  }

  .latest-blog-highlights__nav-btn:focus-visible {
    outline: 2px solid var(--latest-blog-highlight-color);
    outline-offset: 2px;
  }

  .latest-blog-highlights__cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2.5vw, 2rem);
  }

  @media (max-width: 989px) {
    .latest-blog-highlights__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 700px) {
    .latest-blog-highlights__header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }

    .latest-blog-highlights__header-text {
      margin: 0;
      text-align: left;
    }

    .latest-blog-highlights__nav {
      display: inline-flex;
      gap: 0.5rem;
    }

    .latest-blog-highlights__cards--scroll {
      --lbh-desktop-gap: clamp(1rem, 2vw, 1.5rem);
      display: flex;
      gap: var(--lbh-desktop-gap);
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x proximity;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 0.25rem;
    }

    .latest-blog-highlights__cards--scroll::-webkit-scrollbar {
      display: none;
    }

    .latest-blog-highlights__cards--scroll .latest-blog-card {
      flex: 0 0 calc((100% - (var(--lbh-desktop-gap) * 2)) / 3);
      min-width: calc((100% - (var(--lbh-desktop-gap) * 2)) / 3);
      scroll-snap-align: start;
    }
  }

  .latest-blog-card {
    background: rgb(var(--color-foreground) / 0.02);
    border-radius: 24px;
    box-shadow: 0 20px 40px rgb(15 23 42 / 0.08);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .color-inverse .latest-blog-card {
    background: rgb(var(--color-page-background));
  }

  .latest-blog-card__media {
    position: relative;
  }

  .latest-blog-card__image,
  .latest-blog-card__placeholder {
    width: 100%;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 24px 24px 0 0;
  }

  .latest-blog-card__content {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    flex-grow: 1;
  }

  .latest-blog-card__title {
    font-size: 1.25rem;
    margin: 0;
  }

  .latest-blog-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .latest-blog-card__title a:hover {
    color: var(--latest-blog-highlight-color);
  }

  .latest-blog-card__excerpt {
    margin: 0;
    color: color-mix(in srgb, currentColor 70%, transparent);
  }

  .latest-blog-card__link {
    font-weight: 600;
    color: var(--latest-blog-highlight-color);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none;
    margin-top: auto;
  }

  .latest-blog-highlights__footer {
    display: flex;
    justify-content: center;
  }

  .latest-blog-highlights__cta {
    border: none;
    border-radius: 999px;
    padding: 0.85rem 2.5rem;
    background: var(--latest-blog-highlight-color);
    color: #fff;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 150ms ease, box-shadow 150ms ease;
    box-shadow: 0 18px 30px rgb(0 0 0 / 0.15);
  }

  .latest-blog-highlights__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 22px 32px rgb(0 0 0 / 0.18);
  }

  @media (max-width: 699px) {
    .latest-blog-highlights__title {
      font-size: 30px;
    }

    .latest-blog-highlights__subtitle {
      font-size: 16px;
      line-height: normal;
    }

    .latest-blog-highlights__cards {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      --lbh-mobile-gutter: clamp(1rem, 6vw, 1.5rem);
      scroll-padding-inline: var(--lbh-mobile-gutter);
      gap: clamp(0.75rem, 4vw, 1rem);
      padding-bottom: 1rem;
      margin-inline: calc(-1 * var(--lbh-mobile-gutter));
      padding-inline: var(--lbh-mobile-gutter);
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
      cursor: grab;
      user-select: none;
    }

    .latest-blog-highlights__cards.is-dragging,
    .latest-blog-highlights__cards.is-touching {
      cursor: grabbing;
      scroll-snap-type: none;
      scroll-behavior: auto;
    }

    .latest-blog-highlights__cards.is-dragging .latest-blog-card,
    .latest-blog-highlights__cards.is-touching .latest-blog-card {
      pointer-events: none;
    }

    .latest-blog-card {
      width: 75%;
      min-width: 260px;
      max-width: 320px;
      scroll-snap-align: center;
      scroll-snap-stop: always;
      flex: 0 0 auto;
      transition: transform 0.2s ease;
      background: transparent;
      box-shadow: none;
      border-radius: 0;
    }

    .latest-blog-card__image,
    .latest-blog-card__placeholder {
      border-radius: 16px;
    }

    .latest-blog-card__content {
      padding: 1rem 0 0;
    }

    .latest-blog-card__title {
      font-size: 16px;
    }

    .latest-blog-card__image,
    .latest-blog-card__placeholder {
      aspect-ratio: 3 / 2;
    }

    .latest-blog-highlights__cards::-webkit-scrollbar {
      display: none;
    }

    .latest-blog-highlights__footer {
      justify-content: flex-start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Latest blog highlights",
  "tag": "section",
  "class": "latest-blog-highlights-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Latest From"
    },
    {
      "type": "text",
      "id": "heading_prefix",
      "label": "Heading prefix",
      "default": "Latest From"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Highlighted text",
      "default": "Our Blog"
    },
    {
      "type": "text",
      "id": "heading_suffix",
      "label": "Heading suffix",
      "default": "Blog"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Supporting text",
      "default": "Paws-tive insights, tips, and stories from our team"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "article_limit",
      "label": "Number of posts",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "excerpt_words",
      "label": "Excerpt word count",
      "min": 10,
      "max": 50,
      "step": 5,
      "default": 20
    },
    {
      "type": "text",
      "id": "card_cta_label",
      "label": "Card link label",
      "default": "Read More"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show \"View all\" button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "View all button label",
      "default": "View All Posts"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Accent color",
      "default": "#F48F01"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Latest blog highlights",
      "category": "Blogging"
    }
  ]
}
{% endschema %}
