<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<section
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    testimonials-with-product
    spacing-style
  "
  style="{% render 'spacing-style', settings: section.settings %}"
  data-testimonials-section-id="{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="testimonials-with-product__inner">
    {% liquid
      assign heading_full = section.settings.heading
      assign heading_first = section.settings.heading_prefix
      assign heading_middle = section.settings.heading_highlight
      assign heading_last = section.settings.heading_suffix
    %}

    {% if heading_full != blank or heading_first != blank or heading_middle != blank or heading_last != blank or section.settings.subheading != blank %}
      <div class="testimonials-with-product__header">
        <div class="testimonials-with-product__header-text">
          {% if heading_first != blank or heading_middle != blank or heading_last != blank %}
            <h2 class="testimonials-with-product__title">
              {% if heading_first != blank %}
                {{ heading_first }}
              {% endif %}
              {% if heading_middle != blank %}
                <span class="testimonials-with-product__title-highlight">{{ heading_middle }}</span>
              {% endif %}
              {% if heading_last != blank %}
                {{ heading_last }}
              {% endif %}
            </h2>
          {% elsif heading_full != blank %}
            {% if section.settings.highlight_first_word %}
              {% assign words = heading_full | split: ' ' %}
              {% if words.size > 1 %}
                <h2 class="testimonials-with-product__title">
                  <span class="testimonials-with-product__title-highlight">{{ words[0] }}</span>
                  {{ words | slice: 1, words.size | join: ' ' }}
                </h2>
              {% else %}
                <h2 class="testimonials-with-product__title">{{ heading_full }}</h2>
              {% endif %}
            {% else %}
              <h2 class="testimonials-with-product__title">{{ heading_full }}</h2>
            {% endif %}
          {% endif %}

          {% if section.settings.subheading != blank %}
            <p class="testimonials-with-product__eyebrow">{{ section.settings.subheading }}</p>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if section.blocks.size > 1 %}
      <div class="testimonials-with-product__nav-wrapper">
        <button
          class="testimonials-with-product__nav testimonials-with-product__nav--prev"
          type="button"
          aria-label="Previous testimonial"
        >
          &lsaquo;
        </button>
        <button
          class="testimonials-with-product__nav testimonials-with-product__nav--next"
          type="button"
          aria-label="Next testimonial"
        >
          &rsaquo;
        </button>
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="testimonials-with-product__carousel">
        <div class="testimonials-with-product__list">
        {% for block in section.blocks %}
          {% assign product = block.settings.product %}
          <article class="testimonial-card" {{ block.shopify_attributes }}>
            <div class="testimonial-card__media">
              {% if product != blank and product.featured_image != blank %}
                {% assign product_image_alt = product.featured_image.alt | default: product.title %}
                {{
                  product.featured_image
                  | image_url: width: 700
                  | image_tag:
                    loading: 'lazy',
                    alt: product_image_alt,
                    class: 'testimonial-card__image'
                }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'testimonial-card__placeholder' }}
              {% endif %}

              <!-- Desktop: Product pill -->
              {% if product != blank %}
                <div class="testimonial-card__product-pill">
                  <div class="testimonial-card__product-pill-mark"></div>
                  <div class="testimonial-card__product-pill-text">
                    <span class="testimonial-card__product-pill-label">{{ section.settings.product_label | default: 'Product reviewed' }}</span>
                    <span class="testimonial-card__product-pill-title">{{ product.title }}</span>
                  </div>
                </div>
              {% endif %}

              <!-- Mobile: Customer info overlay -->
              <div class="testimonial-card__mobile-overlay">
                <div class="testimonial-card__mobile-overlay-content">
                  <div class="testimonial-card__mobile-left">
                    {% if block.settings.customer_image != blank %}
                      <div class="testimonial-card__mobile-customer-image">
                        {{
                          block.settings.customer_image
                          | image_url: width: 80
                          | image_tag:
                            loading: 'lazy',
                            alt: block.settings.customer_name,
                            class: 'testimonial-card__mobile-customer-avatar'
                        }}
                      </div>
                    {% endif %}
                    <div class="testimonial-card__mobile-info">
                      {% if block.settings.customer_name != blank %}
                        <span class="testimonial-card__mobile-customer-name">{{ block.settings.customer_name }}</span>
                      {% endif %}
                      {% if block.settings.show_rating and block.settings.rating > 0 %}
                        <div class="testimonial-card__mobile-rating" aria-label="{{ block.settings.rating }} out of 5 stars">
                          <div class="testimonial-card__mobile-rating-stars">
                            {% for i in (1..5) %}
                              {% if i <= block.settings.rating %}
                                <span class="testimonial-card__star testimonial-card__star--filled">★</span>
                              {% else %}
                                <span class="testimonial-card__star">★</span>
                              {% endif %}
                            {% endfor %}
                          </div>
                          <span class="testimonial-card__mobile-rating-text">{{ block.settings.rating }} Ratings</span>
                        </div>
                      {% endif %}
                    </div>
                  </div>

                  {% if product != blank %}
                    <a href="{{ product.url }}" class="testimonial-card__mobile-view-product">
                      {{ section.settings.view_product_text | default: 'View Product' }}
                    </a>
                  {% endif %}
                </div>
              </div>
            </div>

            <div class="testimonial-card__content">
              <div class="testimonial-card__header">
                {% if block.settings.customer_image != blank or block.settings.customer_name != blank %}
                  <div class="testimonial-card__customer-info">
                    {% if block.settings.customer_image != blank %}
                      <div class="testimonial-card__customer-image">
                        {{
                          block.settings.customer_image
                          | image_url: width: 100
                          | image_tag:
                            loading: 'lazy',
                            alt: block.settings.customer_name,
                            class: 'testimonial-card__customer-avatar'
                        }}
                      </div>
                    {% endif %}
                    <div class="testimonial-card__customer-details">
                      {% if block.settings.customer_name != blank %}
                        <p class="testimonial-card__customer-name">{{ block.settings.customer_name }}</p>
                      {% endif %}
                      {% if block.settings.customer_badge != blank %}
                        <p class="testimonial-card__customer-badge">{{ block.settings.customer_badge }}</p>
                      {% endif %}
                      {% if block.settings.show_rating and block.settings.rating > 0 %}
                        <div class="testimonial-card__rating" aria-label="{{ block.settings.rating }} out of 5 stars">
                          <div class="testimonial-card__stars">
                            {% for i in (1..5) %}
                              {% if i <= block.settings.rating %}
                                <span class="testimonial-card__star testimonial-card__star--filled">★</span>
                              {% else %}
                                <span class="testimonial-card__star">★</span>
                              {% endif %}
                            {% endfor %}
                          </div>
                          <span class="testimonial-card__rating-divider" aria-hidden="true">|</span>
                          <span class="testimonial-card__rating-text">{{ block.settings.rating }}</span>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
              </div>

              {% if block.settings.headline != blank %}
                <h3 class="testimonial-card__headline">{{ block.settings.headline }}</h3>
              {% endif %}

              {% if block.settings.text != blank %}
                <div class="testimonial-card__text">
                  {{ block.settings.text }}
                </div>
              {% endif %}
            </div>
          </article>
        {% endfor %}
        </div>
      </div>
    {% else %}
      <div class="testimonials-with-product__empty">
        <p>No testimonials have been added yet.</p>
      </div>
    {% endif %}
  </div>
</section>

{% javascript %}
  function initTestimonialsCarousels() {
    var sections = document.querySelectorAll('[data-testimonials-section-id]');

    sections.forEach(function (section) {
      if (section.dataset.testimonialsInit === 'true') return;

      var scroller = section.querySelector('.testimonials-with-product__list');
      var prevButton = section.querySelector('.testimonials-with-product__nav--prev');
      var nextButton = section.querySelector('.testimonials-with-product__nav--next');

      if (!scroller || !prevButton || !nextButton) return;

      var firstCard = scroller.querySelector('.testimonial-card');

      function getScrollAmount() {
        if (firstCard) {
          var rect = firstCard.getBoundingClientRect();
          var cardWidth = rect.width;
          var gap = 24; // matches CSS gap between cards
          return cardWidth + gap;
        }

        return scroller.clientWidth || 0;
      }

      function scrollByAmount(direction) {
        var amount = getScrollAmount() * direction;
        var newLeft = scroller.scrollLeft + amount;

        if (typeof scroller.scrollTo === 'function') {
          scroller.scrollTo({ left: newLeft, behavior: 'smooth' });
        } else {
          scroller.scrollLeft = newLeft;
        }
      }

      prevButton.addEventListener('click', function () {
        scrollByAmount(-1);
        prevButton.classList.add('testimonials-with-product__nav--active');
        nextButton.classList.remove('testimonials-with-product__nav--active');
      });

      nextButton.addEventListener('click', function () {
        scrollByAmount(1);
        nextButton.classList.add('testimonials-with-product__nav--active');
        prevButton.classList.remove('testimonials-with-product__nav--active');
      });

      section.dataset.testimonialsInit = 'true';
    });
  }

  initTestimonialsCarousels();
  document.addEventListener('DOMContentLoaded', initTestimonialsCarousels);
  document.addEventListener('shopify:section:load', initTestimonialsCarousels);
{% endjavascript %}

<style>
  .testimonials-with-product {
    position: relative;
  }

  .testimonials-with-product__inner {
    max-width: 1440px;
    width: 100%;
    margin: 0 auto;
  }

  .testimonials-with-product__header {
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .testimonials-with-product__header-text {
    flex: 1 1 auto;
  }

  .testimonials-with-product__eyebrow {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.08em;
    {% comment %} text-transform: uppercase; {% endcomment %}
    color: rgba(31, 41, 55, 0.7);
    margin: 12px 0 0;
  }

  .testimonials-with-product__title {
    font-size: 60px;
    line-height: 1.1;
    font-weight: 400;
    margin: 0;
    color: var(--color-foreground);
  }

  .testimonials-with-product__title-highlight {
    color: #F48F01;
  }

  .testimonials-with-product__list {
    display: flex;
    flex-direction: row;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 4px 4px 16px;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .testimonials-with-product__list::-webkit-scrollbar {
    display: none;
  }

  .testimonials-with-product__nav-wrapper {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .testimonials-with-product__nav {
    width: 36px;
    height: 36px;
    border-radius: 9999px;
    border: 1px solid rgba(156, 163, 175, 0.5);
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #111827;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
    padding: 0;
    line-height: 1;
  }

  .testimonials-with-product__nav--prev,
  .testimonials-with-product__nav--next {
    background: #ffffff;
    transition: all 0.2s ease;
  }

  .testimonials-with-product__nav--active {
    background: #f59e0b;
    border-color: #f59e0b;
    color: #ffffff;
    box-shadow: 0 10px 25px rgba(245, 158, 11, 0.4);
  }

  .testimonial-card {
    display: flex;
    gap: 28px;
    background: #FFF5D9;
    border-radius: 28px;
    padding: 24px 28px;
    box-shadow: 0 18px 40px rgba(42, 30, 92, 0.12);
    align-items: stretch;
    flex: 0 0 80%;
    max-width: 900px;
    scroll-snap-align: start;
  }

  .testimonial-card__media {
    position: relative;
    flex: 0 0 320px;
    max-width: 320px;
    border-radius: 24px;
    overflow: hidden;
    background: #e5e7eb;
  }

  .testimonial-card__image,
  .testimonial-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .testimonial-card__product-pill {
    position: absolute;
    left: 16px;
    bottom: 16px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.2);
  }

  .testimonial-card__product-pill-mark {
    width: 32px;
    height: 32px;
    border-radius: 12px;
    background: linear-gradient(135deg, #f97316, #facc15);
    flex-shrink: 0;
  }

  .testimonial-card__product-pill-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .testimonial-card__product-pill-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #6b7280;
  }

  .testimonial-card__product-pill-title {
    font-size: 13px;
    font-weight: 400;
    color: #111827;
  }

  .testimonial-card__content {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .testimonial-card__header {
    margin-bottom: 16px;
  }

  .testimonial-card__customer-info {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .testimonial-card__customer-image {
    flex-shrink: 0;
  }

  .testimonial-card__customer-avatar {
    width: 56px;
    height: 56px;
    border-radius: 9999px;
    object-fit: cover;
    display: block;
    border: 2px solid #fff;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.12);
  }

  .testimonial-card__customer-details {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 4px;
  }

  .testimonial-card__customer-name {
    font-weight: 400;
    margin: 0;
    color: #111827;
    font-size: 16px;
  }

  .testimonial-card__customer-badge {
    margin: 0;
    font-size: 12px;
    color: #16a34a;
  }

  .testimonial-card__rating {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 4px;
  }

  .testimonial-card__stars {
    display: inline-flex;
    gap: 3px;
    font-size: 15px;
  }

  .testimonial-card__star {
    color: rgba(251, 191, 36, 0.3);
  }

  .testimonial-card__star--filled {
    color: #fbbf24;
  }

  .testimonial-card__rating-divider {
    color: rgba(17, 24, 39, 0.3);
    font-weight: 600;
    font-size: 13px;
  }

  .testimonial-card__rating-text {
    font-weight: 600;
    color: #4b5563;
    white-space: nowrap;
    font-size: 13px;
  }

  .testimonial-card__headline {
    font-size: 20px;
    font-weight: 400;
    margin: 0 0 10px;
    color: #111827;
  }

  .testimonial-card__text {
    font-size: 15px;
    line-height: 1.7;
    color: #4b5563;
  }

  .testimonials-with-product__empty {
    text-align: center;
    padding: 40px 0;
    color: #6b7280;
    font-size: 14px;
  }

  @media screen and (max-width: 1024px) {
    .testimonial-card {
      padding: 20px;
    }

    .testimonial-card__media {
      flex-basis: 260px;
      max-width: 260px;
    }

    .testimonial-card__customer-avatar {
      width: 50px;
      height: 50px;
    }

    .testimonial-card__customer-name {
      font-size: 15px;
    }
  }

  @media screen and (max-width: 768px) {
    .testimonial-card {
      flex-direction: column;
      flex: 0 0 100%;
      max-width: none;
      padding: 16px;
      gap: 16px;
    }

    .testimonial-card__media {
      max-width: none;
      width: 100%;
      height: 260px;
    }

    /* Hide desktop product pill on mobile */
    .testimonial-card__product-pill {
      display: none;
    }

    /* Hide testimonial text content on mobile */
    .testimonial-card__headline,
    .testimonial-card__text {
      display: none;
    }

    .testimonial-card__header {
      display: block;
    }

    .testimonial-card__customer-info {
      flex-direction: row;
      gap: 10px;
      align-items: center;
    }

    .testimonial-card__customer-avatar {
      width: 40px;
      height: 40px;
    }

    .testimonial-card__customer-details {
      display: flex;
      flex-direction: column;
      padding-top: 0;
      gap: 2px;
    }

    .testimonial-card__customer-name {
      font-size: 14px;
    }

    .testimonial-card__customer-badge {
      font-size: 11px;
    }

    .testimonial-card__rating {
      display: flex;
      font-size: 13px;
      margin-top: 2px;
    }

    .testimonial-card__stars {
      font-size: 13px;
      gap: 2px;
    }

    .testimonial-card__rating-divider {
      font-size: 12px;
    }

    .testimonial-card__rating-text {
      font-size: 12px;
    }

    /* Mobile overlay on product image */
    .testimonial-card__mobile-overlay {
      position: absolute;
      left: 10px;
      right: 10px;
      bottom: 10px;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      border-radius: 14px;
      padding: 8px 12px;
    }

    .testimonial-card__mobile-overlay-content {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }

    .testimonial-card__mobile-left {
      display: flex;
      align-items: center;
      gap: 12px;
      flex: 1;
      min-width: 0;
    }

    .testimonial-card__mobile-customer-image {
      flex-shrink: 0;
    }

    .testimonial-card__mobile-customer-avatar {
      width: 40px;
      height: 40px;
      border-radius: 9999px;
      object-fit: cover;
      display: block;
      border: 2px solid #fff;
      box-shadow: 0 2px 10px rgba(15, 23, 42, 0.15);
    }

    .testimonial-card__mobile-info {
      display: flex;
      flex-direction: column;
      gap: 2px;
      min-width: 0;
    }

    .testimonial-card__mobile-customer-name {
      font-weight: 600;
      font-size: 14px;
      color: #111827;
      line-height: 1.3;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .testimonial-card__mobile-rating {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .testimonial-card__mobile-rating-stars {
      display: flex;
      gap: 1px;
      font-size: 14px;
    }

    .testimonial-card__mobile-rating-text {
      font-size: 12px;
      color: #6b7280;
      white-space: nowrap;
    }

    .testimonial-card__mobile-view-product {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      color: #F48F01;
      font-weight: 600;
      font-size: 13px;
      text-decoration: none;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .testimonial-card__mobile-view-product:hover {
      color: #b51f17;
      text-decoration: underline;
    }

    .testimonial-card__mobile-view-product svg {
      flex-shrink: 0;
    }

    .testimonial-card__content {
      display: none;
    }

    /* Move navigation to bottom on mobile (below carousel) */
    .testimonials-with-product__inner {
      display: flex;
      flex-direction: column;
    }

    .testimonials-with-product__header {
      order: 1;
    }

    .testimonials-with-product__carousel {
      order: 2;
    }

    .testimonials-with-product__nav-wrapper {
      order: 3;
      display: flex;
      justify-content: center;
      margin-top: 20px;
      margin-bottom: 8px;
    }

    .testimonials-with-product__nav {
      width: 40px;
      height: 40px;
      font-size: 20px;
    }
  }

  /* Hide mobile overlay on desktop */
  @media screen and (min-width: 769px) {
    .testimonial-card__mobile-overlay {
      display: none;
    }
  }

  @media screen and (max-width: 749px) {
    .testimonials-with-product__title {
      font-size: 30px;
    }
  }

  @media screen and (max-width: 480px) {
    .testimonial-card {
      padding: 18px;
      border-radius: 20px;
    }

    .testimonial-card__mobile-overlay {
      left: 8px;
      right: 8px;
      bottom: 8px;
      padding: 8px 10px;
    }

    .testimonial-card__mobile-overlay-content {
      gap: 6px;
    }

    .testimonial-card__mobile-left {
      gap: 6px;
    }

    .testimonial-card__mobile-customer-avatar {
      width: 28px;
      height: 28px;
    }

    .testimonial-card__mobile-customer-name {
      font-size: 12px;
    }

    .testimonial-card__mobile-rating-stars {
      font-size: 11px;
    }

    .testimonial-card__mobile-view-product {
      font-size: 11px;
    }

    .testimonial-card__mobile-rating-number {
      font-size: 11px;
    }
  }
</style>

{% schema %}
{
  "name": "Testimonials with product",
  "class": "testimonials-with-product-section",
  "settings": [
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading_prefix",
      "label": "Heading (first part)",
      "default": "What Our"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading highlight",
      "default": "Customers"
    },
    {
      "type": "text",
      "id": "heading_suffix",
      "label": "Heading (last part)",
      "default": "Say"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Full heading (fallback)",
      "default": "What Our Customers Say"
    },
