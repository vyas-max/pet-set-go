<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<section
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    our-stories
    spacing-style
  "
  style="{% render 'spacing-style', settings: section.settings %}"
  data-our-stories-section-id="{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="our-stories__inner">
    <div class="our-stories__header">
      <h2 class="our-stories__title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="our-stories__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="our-stories__carousel">
        <div class="our-stories__list">
          {% for block in section.blocks %}
            {% assign story_product = block.settings.product %}
            <article class="our-stories__card" {{ block.shopify_attributes }}>
              <div class="our-stories__card-image-wrap">
                {% if block.settings.story_image != blank %}
                  <img
                    src="{{ block.settings.story_image | image_url: width: 600 }}"
                    alt="{{ block.settings.story_title | default: 'Story' }}"
                    class="our-stories__card-image"
                    width="600"
                    height="600"
                    loading="lazy"
                  >
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'our-stories__card-image' }}
                {% endif %}

                {% if story_product != blank %}
                  <div class="our-stories__product-overlay">
                    <div class="our-stories__product-thumb">
                      {% if story_product.featured_image != blank %}
                        <img
                          src="{{ story_product.featured_image | image_url: width: 120 }}"
                          alt="{{ story_product.title }}"
                          class="our-stories__product-thumb-image"
                          width="56"
                          height="56"
                          loading="lazy"
                        >
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag: 'our-stories__product-thumb-image' }}
                      {% endif %}
                    </div>
                    <div class="our-stories__product-details">
                      <span class="our-stories__product-name">{{ story_product.title }}</span>
                      <span class="our-stories__product-price">{{ story_product.price | money }}</span>
                    </div>
                    <a href="{{ story_product.url }}" class="our-stories__product-action" aria-label="View product">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M7 5L12 10L7 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  </div>
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>
      </div>

      {% if section.blocks.size > 1 %}
        <div class="our-stories__nav">
          <button class="our-stories__nav-btn our-stories__nav-btn--prev" type="button" aria-label="Previous story">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12.5 5L7.5 10L12.5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="our-stories__nav-btn our-stories__nav-btn--next" type="button" aria-label="Next story">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      {% endif %}
    {% else %}
      <div class="our-stories__empty">
        <p>No stories have been added yet.</p>
      </div>
    {% endif %}
  </div>
</section>

{% javascript %}
  function initOurStoriesCarousels() {
    var sections = document.querySelectorAll('[data-our-stories-section-id]');
    sections.forEach(function(section) {
      if (section.dataset.storiesInit === 'true') return;
      var scroller = section.querySelector('.our-stories__list');
      var prevBtn = section.querySelector('.our-stories__nav-btn--prev');
      var nextBtn = section.querySelector('.our-stories__nav-btn--next');
      if (!scroller || !prevBtn || !nextBtn) return;

      var card = scroller.querySelector('.our-stories__card');
      function getScrollAmount() {
        if (card) {
          var rect = card.getBoundingClientRect();
          return rect.width + 16;
        }
        return scroller.clientWidth || 0;
      }

      prevBtn.addEventListener('click', function() {
        scroller.scrollTo({ left: scroller.scrollLeft - getScrollAmount(), behavior: 'smooth' });
      });
      nextBtn.addEventListener('click', function() {
        scroller.scrollTo({ left: scroller.scrollLeft + getScrollAmount(), behavior: 'smooth' });
      });

      section.dataset.storiesInit = 'true';
    });
  }
  initOurStoriesCarousels();
  document.addEventListener('DOMContentLoaded', initOurStoriesCarousels);
  document.addEventListener('shopify:section:load', initOurStoriesCarousels);
{% endjavascript %}

<style>
  .our-stories__inner {
    max-width: 1440px;
    width: 100%;
    margin: 0 auto;
  }

  .our-stories__header {
    margin-bottom: 32px;
  }

  .our-stories__title {
    font-size: 48px;
    font-weight: 700;
    margin: 0 0 12px;
    color: var(--color-foreground);
  }

  .our-stories__subtitle {
    font-size: 18px;
    color: #6b7280;
    margin: 0;
  }

  .our-stories__list {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 4px 4px 16px;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .our-stories__list::-webkit-scrollbar {
    display: none;
  }

  .our-stories__card {
    flex: 0 0 280px;
    scroll-snap-align: start;
  }

  .our-stories__card-image-wrap {
    position: relative;
    border-radius: 32px;
    overflow: hidden;
    aspect-ratio: 280 / 421;
  }

  .our-stories__card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .our-stories__product-overlay {
    position: absolute;
    left: 16px;
    right: 16px;
    bottom: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }

  .our-stories__product-thumb {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    overflow: hidden;
    background: #f3f4f6;
    flex-shrink: 0;
  }

  .our-stories__product-thumb-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .our-stories__product-details {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .our-stories__product-name {
    font-family: 'Open Sans', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: #1f2937;
    line-height: 17.5px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .our-stories__product-price {
    font-family: 'Open Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: #9ca3af;
    line-height: 16.5px;
  }

  .our-stories__product-action {
    flex-shrink: 0;
    display: flex;
    align-items: flex-start;
    padding-top: 4px;
    color: #1f2937;
    text-decoration: none;
  }

  .our-stories__nav {
    display: flex;
    justify-content: flex-start;
    gap: 16px;
    margin-top: 24px;
  }

  .our-stories__nav-btn {
    width: 48px;
    height: 48px;
    border-radius: 9999px;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .our-stories__nav-btn--prev {
    background: #ffffff;
    color: #111827;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .our-stories__nav-btn--next {
    background: #F29200;
    color: #ffffff;
    box-shadow: 0 4px 12px rgba(242, 146, 0, 0.3);
  }

  .our-stories__empty {
    text-align: center;
    padding: 40px 0;
    color: #6b7280;
  }

  @media screen and (max-width: 749px) {
    .our-stories.section {
      background: #ffffff;
    }

    .our-stories__inner {
      padding: 0 16px;
    }

    .our-stories__header {
      padding: 0 8px;
      margin-bottom: 32px;
    }

    .our-stories__title {
      font-family: 'Inter', sans-serif !important;
      font-size: 30px !important;
      font-weight: 800 !important;
      line-height: 36px !important;
      letter-spacing: -0.6px !important;
      color: #111827 !important;
      margin: 0 0 7px 0;
    }

    .our-stories__subtitle {
      font-family: 'Open Sans', sans-serif !important;
      font-size: 14px !important;
      font-weight: 400 !important;
      line-height: 22.8px !important;
      color: #6b7280 !important;
      max-width: 280px;
      margin: 0;
    }

    .our-stories__carousel {
      padding-top: 0;
    }

    .our-stories__list {
      padding: 0;
      gap: 16px;
      scroll-padding-left: 0;
    }

    .our-stories__card {
      flex: 0 0 280px;
      max-width: 280px;
      scroll-snap-align: start;
    }

    .our-stories__card:first-child {
      scroll-snap-align: start;
    }

    .our-stories__card-image-wrap {
      border-radius: 32px;
      aspect-ratio: 280 / 421;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
    }

    .our-stories__product-overlay {
      left: 16px;
      right: 16px;
      bottom: 16px;
      border-radius: 16px;
      padding: 12px;
      gap: 12px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.04), 0 10px 15px rgba(0, 0, 0, 0.06);
    }

    .our-stories__product-thumb {
      width: 56px;
      height: 56px;
      border-radius: 12px;
    }

    .our-stories__nav {
      padding: 8px 0 0;
      margin-top: 0;
      gap: 16px;
    }

    .our-stories__nav-btn {
      width: 48px;
      height: 48px;
      border-radius: 9999px;
      border: none;
    }

    .our-stories__nav-btn--prev {
      background: #ffffff;
      color: #111827;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      border: none;
    }

    .our-stories__nav-btn--next {
      background: #F29200;
      color: #ffffff;
      box-shadow: 0 4px 12px rgba(242, 146, 0, 0.3);
      border: none;
    }
  }
</style>

{% schema %}
{
  "name": "Our Stories",
  "class": "our-stories-section",
  "settings": [
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "full-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Watch Our Stories"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Lorem Ipsum is simply dummy text of the printing and typesetting industry."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story",
      "settings": [
        {
          "type": "image_picker",
          "id": "story_image",
          "label": "Story image"
        },
        {
          "type": "text",
          "id": "story_title",
          "label": "Story title (alt text)"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Featured product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Stories",
      "category": "Text",
      "blocks": [
        { "type": "story" },
        { "type": "story" },
        { "type": "story" }
      ]
    }
  ]
}
{% endschema %}
