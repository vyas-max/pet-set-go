{% liquid
  assign desktop_image = section.settings.image
  assign mobile_image = section.settings.mobile_image | default: desktop_image
  assign has_image = false

  if desktop_image != blank or mobile_image != blank
    assign has_image = true
  endif

  assign section_height_class = ''
  case section.settings.image_height
    when 'small'
      assign section_height_class = 'image-banner--small'
    when 'medium'
      assign section_height_class = 'image-banner--medium'
    when 'large'
      assign section_height_class = 'image-banner--large'
    when 'full_screen'
      assign section_height_class = 'image-banner--full-screen'
  endcase

  assign mobile_alignment_class = ''
  case section.settings.mobile_content_alignment
    when 'left'
      assign mobile_alignment_class = 'image-banner__content--mobile-left'
    when 'center'
      assign mobile_alignment_class = 'image-banner__content--mobile-center'
    when 'right'
      assign mobile_alignment_class = 'image-banner__content--mobile-right'
  endcase

  assign desktop_position_class = ''
  case section.settings.desktop_content_position
    when 'top-left'
      assign desktop_position_class = 'image-banner__content--top-left'
    when 'top-center'
      assign desktop_position_class = 'image-banner__content--top-center'
    when 'top-right'
      assign desktop_position_class = 'image-banner__content--top-right'
    when 'middle-left'
      assign desktop_position_class = 'image-banner__content--middle-left'
    when 'middle-center'
      assign desktop_position_class = 'image-banner__content--middle-center'
    when 'middle-right'
      assign desktop_position_class = 'image-banner__content--middle-right'
    when 'bottom-left'
      assign desktop_position_class = 'image-banner__content--bottom-left'
    when 'bottom-center'
      assign desktop_position_class = 'image-banner__content--bottom-center'
    when 'bottom-right'
      assign desktop_position_class = 'image-banner__content--bottom-right'
  endcase
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  id="image-banner-{{ section.id }}"
  class="image-banner section section--page-width color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="image-banner__inner {{ section_height_class }}">
    <div class="image-banner__media">
      {% if has_image %}
        <div class="image-banner__image-wrapper image-banner__image-wrapper--desktop">
          {% render 'image', image: desktop_image, class: 'image-banner__image', unset_image_tag: true %}
        </div>
        <div class="image-banner__image-wrapper image-banner__image-wrapper--mobile">
          {% render 'image', image: mobile_image, class: 'image-banner__image', unset_image_tag: true %}
        </div>
      {% else %}
        <div class="image-banner__image-wrapper image-banner__image-wrapper--placeholder">
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'image-banner__image' }}
        </div>
      {% endif %}
    </div>

    <div class="image-banner__content-wrapper {{ desktop_position_class }} {{ mobile_alignment_class }}">
      <div class="image-banner__content">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'heading' %}
              {% if block.settings.heading != blank %}
                <h2 class="image-banner__heading" {{ block.shopify_attributes }}>
                  {{ block.settings.heading }}
                </h2>
              {% endif %}
            {% when 'text' %}
              {% if block.settings.text != blank %}
                <div class="image-banner__text" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </div>
              {% endif %}
            {% when 'button' %}
              {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                <a
                  href="{{ block.settings.button_link }}"
                  class="button image-banner__button"
                  {{ block.shopify_attributes }}
                >
                  <span class="image-banner__button-label">{{ block.settings.button_label }}</span>
                  <span class="image-banner__button-icon">↗</span>
                </a>
              {% endif %}
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .image-banner {
    position: relative;
  }

  .image-banner__inner {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    width: 100%;
 
  }

  .image-banner__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .image-banner__image-wrapper {
    width: 100%;
    height: 100%;
  }

  .image-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .image-banner__content-wrapper {
    position: relative;
    z-index: 1;
    display: flex;
    width: 100%;
    height: 100%;
    padding: var(--spacing-32, 32px);
  }

  .image-banner__content {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 600px;
    align-items: center;
    background-color: rgba(0, 0, 0, 0.3);
    padding: 30px;
    border-radius: 20px;
    color: white;
  }

  .image-banner__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--gap-xs);
    border-radius: 999px;
    --button-color: #ffffff;
    --button-background-color: #F48F01;
    --button-border-color: transparent;
    white-space: nowrap;
    min-width: 200px;
  }

  .image-banner__button-icon {
    font-size: 0.9em;
    line-height: 1;
  }

  .image-banner__heading {
    margin: 0;
  }

  .image-banner__text {
    max-width: 40rem;
  }

  /* Height variants */
  .image-banner--small {
    min-height: 40vh;
  }

  .image-banner--medium {
    min-height: 60vh;
  }

  .image-banner--large {
    min-height: 80vh;
  }

  .image-banner--full-screen {
    min-height: 100svh;
  }

  /* Desktop content positions */
  @media screen and (min-width: 750px) {
    .image-banner__content-wrapper {
      align-items: center;
      justify-content: center;
    }

    .image-banner__content--top-left {
      align-items: flex-start;
      justify-content: flex-start;
    }

    .image-banner__content--top-center {
      align-items: center;
      justify-content: flex-start;
    }

    .image-banner__content--top-right {
      align-items: flex-end;
      justify-content: flex-start;
    }

    .image-banner__content--middle-left {
      align-items: flex-start;
      justify-content: center;
    }

    .image-banner__content--middle-center {
      align-items: center;
      justify-content: start;
      left:10%;
    }

    .image-banner__content--middle-right {
      align-items: flex-end;
      justify-content: center;
    }

    .image-banner__content--bottom-left {
      align-items: flex-start;
      justify-content: flex-end;
    }

    .image-banner__content--bottom-center {
      align-items: center;
      justify-content: flex-end;
    }

    .image-banner__content--bottom-right {
      align-items: flex-end;
      justify-content: flex-end;
    }
  }

  /* Mobile alignment */
  @media screen and (max-width: 749px) {
    .image-banner__content-wrapper {
      align-items: center;
      justify-content: left;
      text-align: center;
    }

    .image-banner__content--mobile-left {
      align-items: flex-start;
      text-align: left;
    }

    .image-banner__content--mobile-center {
      align-items: center;
      text-align: center;
    }

    .image-banner__content--mobile-right {
      align-items: flex-end;
      text-align: right;
    }

    .image-banner__content {
      width: auto;
      max-width: 186px;
      min-width: 186px;
      padding: 10px;
      gap: 12px;
    }

    .image-banner__heading {
      font-size: 1rem;
      line-height: 1.2;
    }

    .image-banner__text {
      font-size: 12px;
    }

    .image-banner__button {
      font-size: 0.8rem;
      padding-block: 4px;
      padding-inline: 14px;
      gap: 6px;
      min-width: 0;
    }

    /* Make banner behave like a horizontal card on mobile */
    .image-banner__inner {
      aspect-ratio: 16 / 9;
    }

    /* Override desktop height classes on mobile so aspect-ratio controls height */
    .image-banner--small,
    .image-banner--medium,
    .image-banner--large {
      min-height: auto;
    }
  }

  /* Desktop vs mobile images */
  .image-banner__image-wrapper--desktop {
    display: block;
  }

  .image-banner__image-wrapper--mobile {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .image-banner__image-wrapper--desktop {
      display: none;
    }

    .image-banner__image-wrapper--mobile {
      display: block;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Image banner",
  "tag": "section",
  "class": "image-banner-wrapper section-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Optional. If empty, the desktop image is used on mobile."
    },
    {
      "type": "select",
      "id": "image_height",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        },
        {
          "value": "full_screen",
          "label": "Full screen"
        }
      ],
      "default": "medium",
      "label": "Banner height"
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "options": [
        {
          "value": "top-left",
          "label": "Top left"
        },
        {
          "value": "top-center",
          "label": "Top center"
        },
        {
          "value": "top-right",
          "label": "Top right"
        },
        {
          "value": "middle-left",
          "label": "Middle left"
        },
        {
          "value": "middle-center",
          "label": "Middle center"
        },
        {
          "value": "middle-right",
          "label": "Middle right"
        },
        {
          "value": "bottom-left",
          "label": "Bottom left"
        },
        {
          "value": "bottom-center",
          "label": "Bottom center"
        },
        {
          "value": "bottom-right",
          "label": "Bottom right"
        }
      ],
      "default": "middle-center",
      "label": "Desktop content position"
    },
    {
      "type": "select",
      "id": "mobile_content_alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center",
      "label": "Mobile content alignment"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Image banner",
          "label": "Heading"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Give customers details about the banner image(s) or content on the template.",
          "label": "Text"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "default": "Button label",
          "label": "Button label",
          "info": "Leave empty to hide the button."
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image banner",
      "category": "Banners",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}
