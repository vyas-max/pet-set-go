{{ 'section-collection-showcase.css' | asset_url | stylesheet_tag }}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    collection-showcase
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
>
  {% if section.settings.heading != blank %}
    <div class="collection-showcase__header">
      <h2 class="collection-showcase__heading">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}

  <div class="collection-showcase__grid">
    {% for block in section.blocks %}
      <div class="collection-showcase__card" {{ block.shopify_attributes }}>
        <a href="{{ block.settings.collection.url }}" class="collection-showcase__link">
          <div class="collection-showcase__image-wrapper">
            {% if block.settings.custom_image != blank %}
              <img
                src="{{ block.settings.custom_image | image_url: width: 600 }}"
                alt="{{ block.settings.custom_title | default: block.settings.collection.title }}"
                class="collection-showcase__image"
                width="600"
                height="600"
                loading="lazy"
              >
            {% elsif block.settings.collection.image != blank %}
              <img
                src="{{ block.settings.collection.image | image_url: width: 600 }}"
                alt="{{ block.settings.collection.image.alt | default: block.settings.collection.title }}"
                class="collection-showcase__image"
                width="600"
                height="{{ 600 | divided_by: block.settings.collection.image.aspect_ratio | round }}"
                loading="lazy"
              >
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'collection-showcase__image' }}
            {% endif %}
          </div>
          <div class="collection-showcase__content">
            {% if block.settings.custom_title != blank %}
              <h3 class="collection-showcase__title">{{ block.settings.custom_title }}</h3>
            {% else %}
              <h3 class="collection-showcase__title">{{ block.settings.collection.title }}</h3>
            {% endif %}
            {% if block.settings.custom_description != blank %}
              <p class="collection-showcase__description">{{ block.settings.custom_description }}</p>
            {% endif %}
          </div>
        </a>
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .collection-showcase {
    --gap: 24px;
  }

  .collection-showcase__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .collection-showcase__heading {
    font-size: 2rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-foreground);
  }

  .collection-showcase__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--gap);
    max-width: 1440px;
    width:100%;
    margin: 0 auto;
  }

  .collection-showcase__card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    background: var(--color-background);
  }

  .collection-showcase__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }

  .collection-showcase__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .collection-showcase__image-wrapper {
    position: relative;
    padding-top: 75%; /* 4:3 aspect ratio */
    overflow: hidden;
  }

  .collection-showcase__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .collection-showcase__card:hover .collection-showcase__image {
    transform: scale(1.05);
  }

  .collection-showcase__content {
    position: relative;
    margin-top: -7.5rem;
    padding: 1.75rem 1.75rem 1.5rem;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.85) 80%, rgba(0, 0, 0, 1) 100%);
    color: #ffffff;
  }

  .collection-showcase__title {
    font-size: 50px;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    color: inherit;
  }

  .collection-showcase__description {
    font-size: 24px;
    line-height: 1.6;
    margin: 0;
    color: inherit;
    opacity: 0.9;
  }

  @media screen and (max-width: 749px) {
    .collection-showcase__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .collection-showcase__image-wrapper {
      padding-top: 0;
      aspect-ratio: 1 / 1;
    }

    @supports not (aspect-ratio: 1 / 1) {
      .collection-showcase__image-wrapper {
        padding-top: 100%; /* Fallback to padding technique on older browsers */
      }
    }

    .collection-showcase__heading {
      font-size: 1.5rem;
    }

    .collection-showcase__title {
      font-size: 30px;
    }

    .collection-showcase__description {
      font-size: 1rem;
    }
  }
</style>

{% schema %}
{
  "name": "Collection Showcase",
  "class": "collection-showcase-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Collection"
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between cards",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "limit": 4,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom image",
          "info": "Optional. Overrides the collection image for this card."
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom title",
          "info": "Overrides the collection title"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom description",
          "info": "Custom description for this collection card"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Showcase",
      "category": "Collections",
      "blocks": [
        {
          "type": "collection",
          "settings": {
            "custom_title": "Winter Collection",
            "custom_description": "Keep your pets warm and stylish with our winter essentials."
          }
        },
        {
          "type": "collection",
          "settings": {
            "custom_title": "Special Collection",
            "custom_description": "Unique items for your beloved companions."
          }
        }
      ],
      "settings": {
        "heading": "Shop by Collection",
        "gap": 24,
        "padding-block-start": 36,
        "padding-block-end": 36
      }
    }
  ]
}
{% endschema %}